---
import { getCollection } from 'astro:content'

import Button from '@/components/atoms/Button.astro'
import BlogCard from '@/components/molecules/BlogCard.astro'
import JsonLD from '@/components/utilities/JsonLD.astro'
import { SITE } from '@/config/site'
import { getAuthor } from '@/data/authors'
import PageLayout from '@/layouts/PageLayout.astro'

const posts = await getCollection('blog', ({ data }) => !data.draft)
const recentPosts = posts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3)

const defaultAuthor = getAuthor(SITE.defaultAuthor)

const siteGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${SITE.url}/#website`,
      url: `${SITE.url}/`,
      name: SITE.title,
      description: SITE.description,
      publisher: { '@id': `${SITE.url}/authors/${defaultAuthor.slug}/#person` },
    },
    {
      '@type': 'Person',
      '@id': `${SITE.url}/authors/${defaultAuthor.slug}/#person`,
      name: defaultAuthor.name,
      url: `${SITE.url}/authors/${defaultAuthor.slug}/`,
      description: defaultAuthor.bio,
      ...(defaultAuthor.links.length > 0 && {
        sameAs: defaultAuthor.links
          .filter((l) => l.href.startsWith('http'))
          .map((l) => l.href),
      }),
    },
  ],
}
---

<PageLayout>
  <JsonLD data={siteGraph} />

  <section class="container mx-auto px-6 py-24 md:px-8 md:py-32">
    <div class="mx-auto max-w-3xl text-center">
      <h1 class="mb-6 font-serif text-4xl font-bold md:text-6xl">
        {SITE.title}
      </h1>
      <p class="text-muted mb-8 text-lg leading-relaxed md:text-xl">
        {SITE.description}
      </p>
      <Button href="/blog/" variant="primary" size="lg">Read the blog</Button>
    </div>
  </section>

  {
    recentPosts.length > 0 && (
      <section class="bg-surface-alt">
        <div class="container mx-auto px-6 py-20 md:px-8">
          <div class="mb-12 flex items-end justify-between">
            <h2 class="font-serif text-3xl font-bold md:text-4xl">Recent posts</h2>
            <a href="/blog/" class="text-accent hover:text-accent-dark font-medium">
              View all →
            </a>
          </div>

          <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
            {recentPosts.map((post) => (
              <BlogCard
                title={post.data.title}
                description={post.data.description}
                href={`/blog/${post.id}/`}
                date={post.data.pubDate}
                authorSlug={post.data.author}
                tags={post.data.tags}
                image={post.data.image}
              />
            ))}
          </div>
        </div>
      </section>
    )
  }
</PageLayout>
