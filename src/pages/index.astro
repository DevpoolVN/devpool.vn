---
import ChapterMark from '@/components/molecules/ChapterMark.astro'
import AboutSection from '@/components/organisms/AboutSection.astro'
import AgendaSection from '@/components/organisms/AgendaSection.astro'
import Hero from '@/components/organisms/Hero.astro'
import RegisterSection from '@/components/organisms/RegisterSection.astro'
import SpeakersSection from '@/components/organisms/SpeakersSection.astro'
import Splash from '@/components/organisms/Splash.astro'
import Ticker from '@/components/organisms/Ticker.astro'
import JsonLD from '@/components/utilities/JsonLD.astro'
import { SITE } from '@/config/site'
import { agenda } from '@/data/agenda'
import { EVENT, heroMeta, ticketRows, tickerItems } from '@/data/event'
import { speakers } from '@/data/speakers'
import { takeaways } from '@/data/takeaways'
import PageLayout from '@/layouts/PageLayout.astro'

const siteGraph = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${SITE.url}/#website`,
  url: `${SITE.url}/`,
  name: SITE.title,
  description: SITE.description,
}
---

<PageLayout>
  <JsonLD data={siteGraph} />

  <Splash />

  <Ticker items={tickerItems} />

  <Hero
    eyebrow="★ TECH SEMINAR · 24.05.2026 · FPT ĐÀ NẴNG"
    titleLine1="JUST SHIP."
    titleLine2="VIBE CODING."
    subtitle="FROM PROMPT TO PRODUCTION"
    paragraph="<strong>2 tiếng. 3 engineer. 1 chủ đề không hype.</strong> Code cùng AI mà vẫn cầm trịch production — từ prompt đầu tiên đến lúc <strong>deploy</strong> chạy xanh."
    meta={heroMeta}
    ticketTitle="Vibe Coding 2026"
    ticketStrip={`★ ADMIT ONE · ID ${EVENT.shortCode}`}
    ticketRows={ticketRows}
    countdownTo={EVENT.date}
  />

  <ChapterMark text="Giới thiệu" />

  <AboutSection
    id="about"
    num="01 · GIỚI THIỆU"
    title="TẠI SAO <span class='text-dp-red'>ĐÁNG</span> ĐẾN"
    description="Không slide marketing. Không hô khẩu hiệu. 3 engineer, 3 talk, 1 chủ đề thật."
    quote="PROMPT LÀ <span class='text-dp-yellow'>DỄ</span>. SHIP MỚI <span class='text-dp-yellow'>KHÓ</span>."
    quoteAttribution="— VIBE CODING 2026 · TECH SEMINAR"
    bodyTitle="AI VIẾT CODE. <span class='text-dp-red'>BẠN</span> GIỮ <span class='bg-dp-yellow text-dp-black px-2 [-webkit-box-decoration-break:clone] [box-decoration-break:clone]'>TAY LÁI</span>."
    body="<strong>Vibe Coding</strong> là tech seminar 2 tiếng tại lab AIT, FPT Đà Nẵng. 1 chủ đề duy nhất: code cùng AI mà vẫn cầm trịch được <strong>production</strong> — không bị agent dắt mũi."
    takeaways={takeaways}
  />

  <ChapterMark text="Diễn giả" side="left" arrow="↓ NEXT" />

  <SpeakersSection
    id="speakers"
    num="02 · NGƯỜI CHIA SẺ"
    title="3 <span class='text-dp-red'>DIỄN GIẢ</span>"
    description="Đang làm prod thật. Không hô khẩu hiệu, không thuyết âm mưu, không bán khoá học."
    speakers={speakers}
  />

  <ChapterMark text="Lịch trình" />

  <AgendaSection
    id="agenda"
    num="03 · LỊCH TRÌNH"
    title="2 TIẾNG · <span class='text-dp-red-soft'>6</span> KHÚC"
    description="14:00 → 16:00. Khung giờ flex được nhưng đừng trễ check-in — BTC sẽ buồn."
    items={agenda}
  />

  <ChapterMark text="Đăng ký" arrow="↓ FORM" side="left" />

  <RegisterSection
    id="register"
    title="VÀO LÀ <span class='text-dp-red'>XONG</span>.<br>SUẤT KHÔNG <span class='text-dp-red'>VÔ HẠN</span>."
    description="Điền 4 ô — mất 30 giây. Lab có giới hạn, đến sớm chọn chỗ tốt."
    eventCode={EVENT.code}
  />
</PageLayout>
