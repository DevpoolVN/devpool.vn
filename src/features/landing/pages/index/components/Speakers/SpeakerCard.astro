---
interface Props {
  index: string
  name: string
  role: string
  bio: string
  avatar?: string
}

const { index, name, role, bio, avatar } = Astro.props
---

<article class="spk-card dp-press dp-bordered bg-dp-paper overflow-hidden flex flex-col shadow-dp-md hover:-translate-x-1 hover:-translate-y-1 hover:shadow-dp-lg">
  <div class="spk-avatar flex items-center justify-center relative py-8 border-b-[3px] border-dp-black [background:radial-gradient(circle,theme(--color-dp-paper)_1.2px,transparent_1.5px)_0_0_/_12px_12px,theme(--color-dp-red)]">
    <div class="spk-frame dp-bordered relative block bg-dp-paper w-[72%] aspect-square shadow-dp-sm">
      <span class="dp-label-mono tracking-dp-wide dp-bordered-sm absolute z-2 top-0 left-3 -translate-x-1/3 -translate-y-1/2 bg-dp-red text-dp-paper text-dp-xs px-2 py-1">{index}</span>
      {
        avatar ? (
          <img class="w-full h-full block object-cover object-[center_20%]" src={avatar} alt={name} loading="lazy" />
        ) : (
          <svg class="w-full h-full block box-border p-[8%]" viewBox="0 0 750 750" aria-hidden="true"><use href="#dp-mask"/></svg>
        )
      }
    </div>
  </div>
  <div class="p-6">
    <h3 class="dp-heading-display text-dp-lg tracking-dp-tight mb-2 leading-none">{name}</h3>
    <div class="dp-label-mono text-dp-sm text-dp-red mb-3">{role}</div>
    <p class="dp-desc">{bio}</p>
  </div>
</article>
