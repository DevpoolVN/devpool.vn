---
import Badge from '@/core/components/Badge.astro'

interface Props {
  time: string
  duration: string
  title: string
  tag?: string
  tagVariant?: 'default' | 'yellow'
  description: string
  by?: string
}

const { time, duration, title, tag, tagVariant = 'default', description, by } = Astro.props

const tagBadgeVariant = tagVariant === 'yellow' ? 'default' : 'red'
---

<div
  class="grid p-4 bg-dp-paper text-dp-black transition-[transform,box-shadow] duration-150 ease-out
         gap-3 grid-cols-[80px_1fr] lg:gap-6 lg:grid-cols-[140px_1fr]
         border-[3px] border-dp-black shadow-dp-sm-red
         hover:-translate-x-0.5 hover:-translate-y-0.5"
>
  <div>
    <div class="font-display text-lg text-dp-red leading-none">{time}</div>
    <Badge variant="outline" class="mt-2 text-dp-dim">{duration}</Badge>
  </div>
  <div>
    <h3 class="font-utility text-[20px] uppercase tracking-[0.5px] mb-1 flex items-center flex-wrap gap-2 font-normal">
      {title}
      {tag && <Badge variant={tagBadgeVariant}>{tag}</Badge>}
    </h3>
    <div class="text-[13px] text-dp-dim leading-[1.55]">{description}</div>
    {by && <div class="font-mono font-semibold text-[10px] tracking-[1.5px] text-dp-red mt-2 uppercase">{by}</div>}
  </div>
</div>
