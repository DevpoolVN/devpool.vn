---
import Container from '@/core/components/Container.astro'
import { agenda } from '../../data/agenda'

import SectionHead from '../SectionHead.astro'
import AgendaItem from './AgendaItem.astro'
---

<section
  id="agenda"
  class="relative overflow-hidden bg-dp-black text-dp-paper py-12 lg:py-24
         before:content-[''] before:absolute before:top-0 before:left-0 before:right-0 before:h-1.5
         before:[background:repeating-linear-gradient(90deg,theme(--color-dp-red)_0_24px,theme(--color-dp-paper)_24px_48px)]"
>
  <Container size="narrow">
    <SectionHead
      variant="dark"
      num="03 · LỊCH TRÌNH"
      title="2 TIẾNG · <span class='text-dp-red-soft'>6</span> KHÚC"
      description="14:00 → 16:00. Khung giờ flex được nhưng đừng trễ check-in — BTC sẽ buồn."
    />
    <div class="flex flex-col gap-3 mt-8">
      {agenda.map((i) => <AgendaItem {...i} />)}
    </div>
  </Container>
</section>
