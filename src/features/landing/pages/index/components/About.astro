---
import Container from '@/core/components/Container.astro'
import { takeaways } from '../data/takeaways'

import SectionHead from './SectionHead.astro'
---

<section
  id="about"
  class="relative overflow-hidden bg-dp-paper py-12 lg:py-24 border-b-[6px] border-dp-red"
>
  <Container>
    <SectionHead
      num="01 · GIỚI THIỆU"
      title="TẠI SAO <span class='text-dp-red'>ĐÁNG</span> ĐẾN"
      description="Không slide marketing. Không hô khẩu hiệu. 3 engineer, 3 talk, 1 chủ đề thật."
    />

    <div class="grid gap-12 items-start grid-cols-1 lg:grid-cols-[1fr_1.4fr]">
      <div class="bg-dp-black text-dp-paper p-8 border-4 border-dp-black shadow-dp-xl-red -rotate-1">
        <span class="block mb-3 w-12 h-12" aria-hidden="true">
          <svg class="w-full h-full block" viewBox="0 0 750 750"><use href="#dp-mask"/></svg>
        </span>
        <div class="font-utility text-[22px] uppercase leading-[1.15]">
          PROMPT LÀ <span class="text-dp-yellow">DỄ</span>. SHIP MỚI <span class="text-dp-yellow">KHÓ</span>.
        </div>
        <div class="font-mono font-semibold text-[11px] uppercase tracking-[1.5px] text-dp-red-soft mt-4">— VIBE CODING 2026 · TECH SEMINAR</div>
      </div>

      <div>
        <h2 class="font-display uppercase mb-6 text-[clamp(28px,4vw,44px)] leading-[1.2]">
          AI VIẾT CODE. <span class="text-dp-red">BẠN</span> GIỮ
          <span class="bg-dp-yellow text-dp-black px-2 [-webkit-box-decoration-break:clone] [box-decoration-break:clone]">TAY LÁI</span>.
        </h2>
        <p class="text-base mb-4 text-dp-black leading-[1.65] [&_strong]:bg-dp-red [&_strong]:text-dp-paper [&_strong]:px-1">
          <strong>Vibe Coding</strong> là tech seminar 2 tiếng tại lab AIT, FPT Đà Nẵng. 1 chủ đề
          duy nhất: code cùng AI mà vẫn cầm trịch được <strong>production</strong> — không bị agent
          dắt mũi.
        </p>
        <ul class="list-none flex flex-col gap-3 mt-6">
          {takeaways.map((t) => (
            <li class="grid items-start gap-4 p-4 bg-dp-cream grid-cols-[36px_1fr] border-[2.5px] border-dp-black">
              <div class="flex items-center justify-center bg-dp-red text-dp-paper font-display text-sm w-8 h-8 border-[2.5px] border-dp-black">{t.index}</div>
              <div>
                <h3 class="font-utility text-[15px] uppercase tracking-[0.5px] text-dp-black font-normal">{t.title}</h3>
                <div class="text-[13px] text-dp-dim mt-1 leading-[1.55]">{t.description}</div>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </Container>
</section>

