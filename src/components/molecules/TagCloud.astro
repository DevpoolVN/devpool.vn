---
import { slugify } from '@/lib/slug'

interface Props {
  tags: Array<{ tag: string; count: number }>
  class?: string
}

const { tags, class: className = '' } = Astro.props
---

{
  tags.length > 0 && (
    <div class:list={[className]}>
      <p class="text-muted mb-3 text-xs font-semibold tracking-wider uppercase">Tags</p>
      <div class="flex flex-wrap gap-2">
        {tags.map(({ tag, count }) => (
          <a
            href={`/blog/tags/${slugify(tag)}/`}
            class="bg-surface-alt text-ink hover:bg-accent inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-sm transition-colors hover:text-white"
          >
            <span>{tag}</span>
            <span class="text-muted text-xs">{count}</span>
          </a>
        ))}
      </div>
    </div>
  )
}
