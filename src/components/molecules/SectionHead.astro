---
interface Props {
  num: string
  title: string
  description?: string
}

const { num, title, description } = Astro.props
---

<div class="sec-head">
  <div>
    <div class="sec-num">{num}</div>
    <h2 class="sec-title" set:html={title} />
  </div>
  {description && <p class="sec-desc">{description}</p>}
</div>

<style>
  @reference '@/styles/global.css';
  .sec-head {
    @apply flex items-end justify-between flex-wrap gap-4 mb-12;
  }
  .sec-num {
    @apply block font-mono font-semibold text-[11px] uppercase tracking-[2px] mb-6;
    color: var(--sec-num-color, var(--color-dp-dim));
  }
  .sec-title {
    @apply font-display uppercase mb-4;
    font-size: clamp(32px, 5vw, 56px);
    line-height: 1.2;
    color: var(--sec-title-color, var(--color-dp-black));
  }
  .sec-desc {
    @apply font-hand text-lg max-w-95;
    color: var(--sec-desc-color, var(--color-dp-black));
  }
</style>
