---
interface Props {
  id: string
  name: string
  label: string
  type?: 'text' | 'email' | 'tel' | 'textarea'
  placeholder?: string
  required?: boolean
  optional?: boolean
  autocomplete?: string
  inputmode?: 'text' | 'tel' | 'email' | 'numeric' | 'decimal' | 'search' | 'url'
  hint?: string
  optionalLabel?: string
}

const {
  id,
  name,
  label,
  type = 'text',
  placeholder,
  required = false,
  optional = false,
  autocomplete,
  inputmode,
  hint,
  optionalLabel = '(không bắt buộc)',
} = Astro.props
---

<div class="field">
  <label for={id}>
    {label}
    {required && <span class="req">*</span>}
    {optional && <span class="opt">{optionalLabel}</span>}
  </label>
  {
    type === 'textarea' ? (
      <textarea id={id} name={name} placeholder={placeholder} required={required} />
    ) : (
      <input
        id={id}
        name={name}
        type={type}
        placeholder={placeholder}
        required={required}
        autocomplete={autocomplete}
        inputmode={inputmode}
      />
    )
  }
  {hint && <div class="field-hint">{hint}</div>}
</div>

<style>
  @reference '@/styles/global.css';
  .field label {
    @apply block font-sans text-[13px] font-bold text-dp-paper mb-2;
  }
  .field label .req { @apply text-dp-red-soft ml-0.5; }
  .field label .opt { @apply font-normal text-[11px] text-dp-paper opacity-55 ml-1; }
  .field input,
  .field textarea,
  .field select {
    @apply w-full font-sans text-sm p-3 bg-dp-paper text-dp-black;
    border: 3px solid var(--dp-paper);
    box-shadow: var(--shadow-dp-sm-red);
    transition: transform var(--dur-fast) ease-out, box-shadow var(--dur-fast) ease-out;
  }
  .field textarea { min-height: 110px; resize: vertical; }
  .field input:focus,
  .field textarea:focus,
  .field select:focus {
    @apply outline-none;
    box-shadow: var(--shadow-dp-md);
    transform: translate(-1px, -1px);
    border-color: var(--dp-red);
  }
  .field-hint { @apply font-sans text-xs italic text-dp-paper opacity-65 mt-1; }
</style>
