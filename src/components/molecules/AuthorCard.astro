---
import Icon from '@/components/atoms/Icon.astro'
import type { Author } from '@/data/authors'

interface Props {
  author: Author
  variant?: 'compact' | 'full'
  class?: string
}

const { author, variant = 'compact', class: className = '' } = Astro.props
---

{
  variant === 'compact' && (
    <a
      href={`/authors/${author.slug}/`}
      class:list={[
        'border-border hover:border-accent flex items-center gap-3 rounded-2xl border p-4 transition-colors',
        className,
      ]}
    >
      {author.avatar ? (
        <img
          src={author.avatar}
          alt={author.name}
          class="h-12 w-12 shrink-0 rounded-full object-cover"
          loading="lazy"
        />
      ) : (
        <div class="bg-surface-alt flex h-12 w-12 shrink-0 items-center justify-center rounded-full font-serif text-xl font-bold">
          {author.name.charAt(0)}
        </div>
      )}
      <div class="min-w-0">
        <p class="text-ink truncate font-semibold">{author.name}</p>
        {author.role && <p class="text-muted truncate text-sm">{author.role}</p>}
      </div>
    </a>
  )
}

{
  variant === 'full' && (
    <div class:list={['flex flex-col items-center gap-6 text-center md:flex-row md:text-left', className]}>
      {author.avatar ? (
        <img
          src={author.avatar}
          alt={author.name}
          class="h-32 w-32 shrink-0 rounded-full object-cover"
          loading="lazy"
        />
      ) : (
        <div class="bg-surface-alt flex h-32 w-32 shrink-0 items-center justify-center rounded-full font-serif text-4xl font-bold">
          {author.name.charAt(0)}
        </div>
      )}

      <div class="flex-1">
        <h1 class="mb-1 font-serif text-4xl font-bold">{author.name}</h1>
        {author.role && <p class="text-muted mb-1">{author.role}</p>}
        {author.location && (
          <p class="text-muted mb-4 inline-flex items-center gap-1 text-sm">
            <Icon name="lucide:map-pin" class="h-4 w-4" />
            {author.location}
          </p>
        )}
        <p class="text-ink mb-6 leading-relaxed">{author.bio}</p>

        {author.links.length > 0 && (
          <ul class="flex flex-wrap justify-center gap-3 md:justify-start">
            {author.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  target={link.href.startsWith('http') ? '_blank' : undefined}
                  rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
                  class="border-border text-ink hover:border-accent hover:text-accent inline-flex items-center gap-2 rounded-full border px-4 py-2 text-sm font-medium transition-colors"
                >
                  {link.icon && <Icon name={link.icon} class="h-4 w-4" />}
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        )}
      </div>
    </div>
  )
}
