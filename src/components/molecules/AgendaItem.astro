---
interface Props {
  time: string
  duration: string
  title: string
  tag?: string
  tagVariant?: 'default' | 'yellow'
  description: string
  by?: string
}

const { time, duration, title, tag, tagVariant = 'default', description, by } = Astro.props
---

<div class="tl-item">
  <div>
    <div class="tl-time">{time}</div>
    <div class="tl-dur">{duration}</div>
  </div>
  <div>
    <h3 class="tl-title">
      {title}
      {tag && <span class:list={['tl-tag', tagVariant === 'yellow' && 'yel']}>{tag}</span>}
    </h3>
    <div class="tl-desc">{description}</div>
    {by && <div class="tl-by">{by}</div>}
  </div>
</div>

<style>
  @reference '@/styles/global.css';
  .tl-item {
    @apply grid gap-6 p-4 bg-dp-paper text-dp-black transition-[transform,box-shadow] duration-150 ease-out;
    grid-template-columns: 140px 1fr;
    border: 3px solid var(--dp-black);
    box-shadow: var(--shadow-dp-sm-red);
  }
  .tl-item:hover { transform: translate(-2px, -2px); }
  .tl-time { @apply font-display text-lg text-dp-red leading-none; }
  .tl-dur {
    @apply font-mono font-semibold text-[10px] tracking-[1.5px] text-dp-dim mt-2;
  }
  .tl-title {
    @apply font-utility text-[20px] uppercase tracking-[0.5px] mb-1 flex items-center flex-wrap gap-2;
    font-weight: normal;
  }
  .tl-desc { @apply text-[13px] text-dp-dim; line-height: 1.55; }
  .tl-by {
    @apply font-mono font-semibold text-[10px] tracking-[1.5px] text-dp-red mt-2 uppercase;
  }
  .tl-tag {
    @apply inline-block bg-dp-red text-dp-paper font-mono font-semibold text-[9px] tracking-[1.5px] uppercase px-2;
    padding: 2px 8px;
    border: 1.5px solid var(--dp-black);
  }
  .tl-tag.yel { @apply bg-dp-yellow text-dp-black; }

  @media (max-width: 1023px) {
    .tl-item { grid-template-columns: 80px 1fr; @apply gap-3; }
  }
</style>
