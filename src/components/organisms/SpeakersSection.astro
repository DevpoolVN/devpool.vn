---
import SectionHead from '@/components/molecules/SectionHead.astro'
import SpeakerCard from '@/components/molecules/SpeakerCard.astro'

interface Speaker {
  index: string
  name: string
  role: string
  bio: string
  avatar?: string
}

interface Props {
  id?: string
  num: string
  title: string
  description?: string
  speakers: Speaker[]
}

const { id = 'speakers', num, title, description, speakers } = Astro.props
---

<section id={id} class="speakers-section">
  <div class="speakers-inner">
    <SectionHead num={num} title={title} description={description} />
    <div class="spk-grid">
      {speakers.map((s) => <SpeakerCard {...s} />)}
    </div>
  </div>
</section>

<style>
  @reference '@/styles/global.css';
  .speakers-section {
    @apply py-24;
    background:
      radial-gradient(circle, var(--dp-red) 1px, transparent 1.5px) 0 0 / 16px 16px,
      var(--dp-cream);
  }
  .speakers-inner {
    max-width: var(--w-full);
    @apply mx-auto px-6;
  }
  .spk-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 24px;
    align-items: stretch;
  }
  @media (max-width: 1023px) {
    .speakers-section { @apply py-12; }
  }
</style>
