---
import Button from '@/components/core/Button.astro'
import { CTA, NAV, SITE } from '@/config/site'

const tag = 'WORKSHOP'
---

<nav class="appbar" aria-label="Main" transition:persist>
  <a href="#top" class="ab-brand" aria-label={`${SITE.title} Workshop`}>
    <span class="wordmark">
      DEVP<svg aria-hidden="true"><use href="#dp-mask"/></svg><svg aria-hidden="true"><use href="#dp-mask"/></svg>L
    </span>
    <span class="slash">/</span>
    <span>{tag}</span>
  </a>

  <ul class="ab-menu" id="ab-menu">
    {NAV.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
  </ul>

  <button class="ab-menu-toggle" id="ab-menu-toggle" aria-label="Mở menu" aria-expanded="false" aria-controls="ab-menu">
    <span></span><span></span><span></span>
  </button>

  <Button href={CTA.href} arrow class="ab-cta">{CTA.label}</Button>
</nav>

<script is:inline>
  (function(){
    const btn = document.getElementById('ab-menu-toggle');
    const menu = document.getElementById('ab-menu');
    if (!btn || !menu || btn.dataset.bound) return;
    btn.dataset.bound = '1';
    btn.addEventListener('click', () => {
      const open = menu.classList.toggle('open');
      btn.setAttribute('aria-expanded', String(open));
    });
    menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => {
      menu.classList.remove('open');
      btn.setAttribute('aria-expanded', 'false');
    }));
  })();
</script>

<style>
  @reference '@/styles/global.css';
  .appbar {
    @apply sticky top-0 z-100 bg-dp-black text-dp-paper flex justify-between items-center gap-4 px-6 py-3;
    border-bottom: 6px solid var(--dp-red);
  }
  .ab-brand {
    @apply font-display text-[20px] tracking-[1px] flex items-center gap-2 text-dp-paper no-underline;
  }
  .ab-brand .slash { @apply text-dp-red-soft mx-1; }
  .ab-brand .wordmark {
    @apply inline-flex items-center leading-none font-display;
  }
  .ab-brand .wordmark svg { width: 1em; height: 1em; flex-shrink: 0; }

  .ab-menu { @apply flex gap-2 list-none m-0 p-0; }
  .ab-menu a {
    @apply text-dp-paper no-underline font-mono font-semibold text-[11px] uppercase tracking-[1.5px] px-3 py-2 inline-block;
    border: 1.5px solid transparent;
    transition: border-color var(--dur-fast) ease-out;
  }
  .ab-menu a:hover { border-color: var(--dp-red-soft); }
  .ab-menu a[aria-current="page"] { @apply text-dp-red-soft; border-color: var(--dp-red-soft); }

  .ab-menu-toggle {
    @apply hidden bg-transparent cursor-pointer flex-col gap-1 p-2;
    border: 2px solid var(--dp-paper);
  }
  .ab-menu-toggle span {
    @apply block bg-dp-paper;
    width: 20px; height: 2.5px;
    transition: transform var(--dur-fast) ease-out, opacity var(--dur-fast);
  }
  .ab-menu-toggle[aria-expanded="true"] span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .ab-menu-toggle[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .ab-menu-toggle[aria-expanded="true"] span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  @media (max-width: 1023px) {
    .ab-menu {
      @apply hidden absolute flex-col bg-dp-black;
      top: calc(100% + 6px); left: 0; right: 0;
      padding: 0; gap: 0;
      border-bottom: 6px solid var(--dp-red);
    }
    .ab-menu.open { @apply flex; }
    .ab-menu li { @apply block; }
    .ab-menu a {
      @apply block text-left text-dp-paper px-6 py-6 font-utility text-sm tracking-[2px] uppercase;
      border: none;
      border-bottom: 1px solid color-mix(in srgb, var(--dp-paper) 10%, var(--dp-black));
      transition: color var(--dur-fast), padding-left var(--dur-fast);
    }
    .ab-menu li:last-child a { border-bottom: none; }
    .ab-menu a:hover, .ab-menu a[aria-current="page"] {
      @apply text-dp-red-soft bg-transparent;
      padding-left: 32px;
    }
    .ab-menu-toggle { @apply flex; }
    :global(.ab-cta) { @apply hidden; }
    .ab-brand .slash, .ab-brand > span:last-child { @apply hidden; }
  }
</style>
