---
import NavLink from '@/components/molecules/NavLink.astro'
import ThemeToggle from '@/components/utilities/ThemeToggle.astro'
import { NAV, SITE } from '@/config/site'

const currentPath = Astro.url.pathname
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href)
---

<header
  class="border-border bg-surface/80 sticky top-0 z-50 border-b backdrop-blur"
  transition:persist
>
  <nav class="container mx-auto px-6 md:px-8">
    <div class="flex h-16 items-center justify-between md:h-20">
      <a href="/" class="text-ink flex items-center gap-2.5">
        <img
          src="/favicon.svg"
          alt=""
          aria-hidden="true"
          class="h-8 w-auto shrink-0 md:h-9"
        />
        <span class="font-serif text-2xl font-bold">{SITE.title}</span>
      </a>

      <div class="flex items-center gap-6 md:gap-8">
        <ul class="hidden items-center gap-6 md:flex md:gap-8">
          {
            NAV.map((item) => (
              <li>
                <NavLink href={item.href} active={isActive(item.href)}>
                  {item.label}
                </NavLink>
              </li>
            ))
          }
        </ul>

        <ThemeToggle />
      </div>
    </div>
  </nav>
</header>
