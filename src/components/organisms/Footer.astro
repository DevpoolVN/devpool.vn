---
import { SITE } from '@/config/site'

const currentYear = new Date().getFullYear()
---

<footer>
  <div class="ft-term" role="contentinfo">
    <div><span class="ft-prompt">$</span><span class="ft-cmd">devpool seminar register <span class="flag">--event</span> vibe-coding-2026</span></div>

    <div class="ft-divider">// ────── event metadata ──────────────────────────────────</div>

    <div><span class="ft-arrow-out">→</span><span class="ft-key">name      </span><span class="ft-val">"Vibe Coding: From Prompt to Production"</span></div>
    <div><span class="ft-arrow-out">→</span><span class="ft-key">when      </span><span class="ft-val">Sun, 2026-05-24 · 14:00 GMT+7</span></div>
    <div><span class="ft-arrow-out">→</span><span class="ft-key">where     </span><span class="ft-val">Gamma 101 · FPT Đà Nẵng (Ngũ Hành Sơn)</span></div>
    <div><span class="ft-arrow-out">→</span><span class="ft-key">speakers  </span><span class="ft-val">3 engineers · AxonActive × Enosta</span></div>
    <div><span class="ft-arrow-out">→</span><span class="ft-key">price     </span><span class="ft-val"><code>0₫</code> · 100% free</span></div>
    <div class="ft-warn"><span class="ft-arrow-out">!</span><span class="ft-val">limited seats · run <code>./register</code> while you can</span></div>

    <a href="#register" class="ft-cta-line">
      <span class="ft-prompt">$</span><span class="ft-cmd">./register-now</span><span class="ft-cursor"></span>
    </a>

    <div class="ft-divider">// ────── ////////////////////// ──────────────────────────</div>

    <div class="ft-comment">// © {currentYear} {SITE.title} · #VibeCoding2026 · <a href="#top">scroll_to_top()</a></div>
  </div>
</footer>

<style>
  @reference '@/styles/global.css';
  footer {
    @apply bg-dp-black text-dp-paper relative overflow-hidden;
    border-top: 6px solid var(--dp-red);
  }
  .ft-term {
    max-width: var(--w-card); @apply mx-auto py-24 px-6 font-mono font-semibold text-sm;
    line-height: 1.8;
  }
  .ft-prompt { @apply text-dp-red-soft mr-2 select-none; }
  .ft-cmd { @apply text-dp-paper; }
  .ft-cmd .flag { @apply text-dp-yellow; }
  .ft-arrow-out {
    color: color-mix(in srgb, var(--dp-paper) 40%, var(--dp-black));
    @apply mr-2 select-none;
  }
  .ft-key { @apply text-dp-yellow mr-2; }
  .ft-val { @apply text-dp-paper; }
  .ft-val code {
    background: color-mix(in srgb, var(--dp-paper) 12%, var(--dp-black));
    padding: 0 4px; @apply font-mono;
  }
  .ft-warn { @apply text-dp-red-soft; }
  .ft-comment {
    color: color-mix(in srgb, var(--dp-paper) 45%, var(--dp-black));
    @apply italic;
  }
  .ft-comment a {
    color: color-mix(in srgb, var(--dp-paper) 70%, var(--dp-black));
    @apply no-underline transition-colors;
    border-bottom: 1px dotted currentColor;
  }
  .ft-comment a:hover { @apply text-dp-yellow; }
  .ft-cta-line {
    @apply block my-6 py-3 px-4 no-underline text-dp-paper transition-[background-color,border-color] duration-150;
    background: color-mix(in srgb, var(--dp-paper) 6%, var(--dp-black));
    border-left: 3px solid var(--dp-red);
  }
  .ft-cta-line:hover {
    background: color-mix(in srgb, var(--dp-paper) 10%, var(--dp-black));
    border-left-color: var(--dp-yellow);
  }
  .ft-cta-line .ft-cmd { @apply text-dp-yellow; font-weight: 600; }
  .ft-cta-line .ft-cursor {
    @apply inline-block bg-dp-yellow;
    width: 8px; height: 1em;
    vertical-align: text-bottom; margin-left: 4px;
    animation: blink 1s steps(2) infinite;
  }
  .ft-divider {
    color: color-mix(in srgb, var(--dp-paper) 25%, var(--dp-black));
    @apply select-none overflow-hidden my-4 whitespace-nowrap;
  }

  @keyframes blink { 0%, 50% { opacity: 1; } 51%, 100% { opacity: 0; } }

  @media (max-width: 1023px) {
    .ft-term { @apply py-12 px-6 text-xs; line-height: 1.7; }
    .ft-key { @apply inline-block; min-width: 80px; }
  }
</style>
