---
import Icon from '@/components/atoms/Icon.astro'
import { NAV, SITE } from '@/config/site'

const currentYear = new Date().getFullYear()
---

<footer class="border-border bg-surface-alt border-t">
  <div class="container mx-auto px-6 py-12 md:px-8">
    <div class="flex flex-col items-center justify-between gap-6 md:flex-row">
      <div>
        <p class="font-serif text-xl font-bold">{SITE.title}</p>
        <p class="text-muted mt-1 text-sm">{SITE.description}</p>
      </div>

      <ul class="flex flex-wrap items-center justify-center gap-6">
        {
          NAV.map((item) => (
            <li>
              <a href={item.href} class="text-muted hover:text-accent text-sm transition-colors">
                {item.label}
              </a>
            </li>
          ))
        }
        <li>
          <a
            href="/rss.xml"
            class="text-muted hover:text-accent inline-flex items-center gap-1.5 text-sm transition-colors"
          >
            <Icon name="lucide:rss" class="h-4 w-4" />
            RSS
          </a>
        </li>
      </ul>
    </div>

    <div class="border-border text-muted mt-8 border-t pt-6 text-center text-sm">
      © {currentYear} {SITE.title}. All rights reserved.
    </div>
  </div>
</footer>
