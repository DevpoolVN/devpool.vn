---
import SectionHead from '@/components/molecules/SectionHead.astro'

interface Takeaway {
  index: string
  title: string
  description: string
}

interface Props {
  id?: string
  num: string
  title: string
  description?: string
  quote: string
  quoteAttribution?: string
  bodyTitle: string
  body: string
  takeaways?: Takeaway[]
}

const {
  id = 'about',
  num,
  title,
  description,
  quote,
  quoteAttribution,
  bodyTitle,
  body,
  takeaways = [],
} = Astro.props
---

<section id={id} class="about">
  <div class="about-inner">
    <SectionHead num={num} title={title} description={description} />

    <div class="about-grid">
      <div class="about-quote">
        <span class="mark" aria-hidden="true">
          <svg viewBox="0 0 750 750"><use href="#dp-mask"/></svg>
        </span>
        <div class="quote-text" set:html={quote} />
        {quoteAttribution && <div class="quote-attr">{quoteAttribution}</div>}
      </div>
      <div class="about-body">
        <h2 set:html={bodyTitle} />
        <p set:html={body} />
        {
          takeaways.length > 0 && (
            <ul class="takeaway-list">
              {takeaways.map((t) => (
                <li>
                  <div class="takeaway-num">{t.index}</div>
                  <div>
                    <h3 class="takeaway-title">{t.title}</h3>
                    <div class="takeaway-desc">{t.description}</div>
                  </div>
                </li>
              ))}
            </ul>
          )
        }
      </div>
    </div>
  </div>
</section>

<style>
  @reference '@/styles/global.css';
  .about {
    @apply relative overflow-hidden bg-dp-paper py-24 px-6;
    border-bottom: 6px solid var(--dp-red);
  }
  .about-inner { max-width: var(--w-full); @apply mx-auto; }
  .about-grid {
    display: grid; grid-template-columns: 1fr 1.4fr; gap: 48px; align-items: start;
  }
  .about-quote {
    @apply bg-dp-black text-dp-paper p-8;
    border: 4px solid var(--dp-black);
    box-shadow: var(--shadow-dp-xl-red);
    transform: rotate(-1deg);
  }
  .about-quote .mark { @apply block mb-3; width: 48px; height: 48px; }
  .about-quote .mark svg { @apply w-full h-full block; }
  .about-quote .quote-text { @apply font-utility text-[22px] uppercase; line-height: 1.15; }
  .about-quote .quote-attr {
    @apply font-mono font-semibold text-[11px] uppercase tracking-[1.5px] text-dp-red-soft mt-4;
  }
  .about-body h2 {
    @apply font-display uppercase mb-6;
    font-size: clamp(28px, 4vw, 44px); line-height: 1.2;
  }
  .about-body p { @apply text-base mb-4 text-dp-black; line-height: 1.65; }
  /* :global() — strong tag arrives via set:html, no scope hash */
  .about-body p :global(strong) { @apply bg-dp-red text-dp-paper px-1; }
  .takeaway-list {
    @apply list-none flex flex-col gap-3 mt-6;
  }
  .takeaway-list li {
    @apply grid items-start gap-4 p-4 bg-dp-cream;
    grid-template-columns: 36px 1fr;
    border: 2.5px solid var(--dp-black);
  }
  .takeaway-num {
    @apply flex items-center justify-center bg-dp-red text-dp-paper font-display text-sm;
    width: 32px; height: 32px;
    border: 2.5px solid var(--dp-black);
  }
  .takeaway-title {
    @apply font-utility text-[15px] uppercase tracking-[0.5px] text-dp-black;
    font-weight: normal;
  }
  .takeaway-desc { @apply text-[13px] text-dp-dim mt-1; line-height: 1.55; }

  @media (max-width: 1023px) {
    .about { @apply px-6 py-12; }
    .about-grid { grid-template-columns: 1fr; }
  }
</style>
