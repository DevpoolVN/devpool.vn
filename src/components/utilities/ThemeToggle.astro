---
import Icon from '@/components/atoms/Icon.astro'
---

<button
  type="button"
  id="theme-toggle"
  class="text-ink hover:text-accent inline-flex h-9 w-9 items-center justify-center rounded-full transition-colors"
  aria-label="Toggle theme"
>
  <Icon name="lucide:sun" class="sun-icon h-5 w-5" />
  <Icon name="lucide:moon" class="moon-icon hidden h-5 w-5" />
</button>

<style is:global>
  .dark #theme-toggle .sun-icon {
    display: none;
  }
  .dark #theme-toggle .moon-icon {
    display: inline-block;
  }
</style>

<script>
  // The button lives inside a transition:persist header, so the click
  // listener survives view-transition swaps. Attach once, idempotently.
  const btn = document.getElementById('theme-toggle')
  if (btn && !btn.dataset.themeBound) {
    btn.dataset.themeBound = '1'
    btn.addEventListener('click', () => {
      const isDark = document.documentElement.classList.toggle('dark')
      try {
        localStorage.setItem('theme', isDark ? 'dark' : 'light')
      } catch {
        /* noop */
      }
    })
  }
</script>
