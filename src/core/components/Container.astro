---
import { cva, type VariantProps } from 'class-variance-authority'

import { cn } from '@/core/utils/cn'

const containerVariants = cva('mx-auto w-full px-4 sm:px-6 lg:px-8', {
  variants: {
    size: {
      narrow: 'max-w-4xl',
      default: 'max-w-7xl',
      wide: 'max-w-screen-2xl',
    },
  },
  defaultVariants: {
    size: 'default',
  },
})

type AsTag = 'div' | 'section' | 'header' | 'footer' | 'nav' | 'main' | 'article'

interface Props extends VariantProps<typeof containerVariants> {
  as?: AsTag
  id?: string
  class?: string
}

const { as: Tag = 'div', id, size, class: className } = Astro.props
---

<Tag id={id} class={cn(containerVariants({ size, className }))}>
  <slot />
</Tag>
