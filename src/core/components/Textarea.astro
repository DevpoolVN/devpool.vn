---
import { cva, type VariantProps } from 'class-variance-authority'

import { cn } from '@/core/utils/cn'

const textareaVariants = cva('dp-control min-h-28 resize-y', {
  variants: {
    variant: {
      default: '',
      error: 'dp-control-error',
    },
  },
  defaultVariants: {
    variant: 'default',
  },
})

interface Props extends VariantProps<typeof textareaVariants> {
  name?: string
  id?: string
  value?: string
  placeholder?: string
  required?: boolean
  disabled?: boolean
  readonly?: boolean
  rows?: number
  maxlength?: number
  minlength?: number
  'aria-label'?: string
  'aria-describedby'?: string
  'aria-invalid'?: boolean | 'true' | 'false'
  class?: string
}

const {
  name,
  id,
  value,
  placeholder,
  required = false,
  disabled = false,
  readonly = false,
  rows,
  maxlength,
  minlength,
  variant,
  'aria-label': ariaLabel,
  'aria-describedby': ariaDescribedby,
  'aria-invalid': ariaInvalid,
  class: className,
} = Astro.props
---

<textarea
  name={name}
  id={id}
  placeholder={placeholder}
  required={required}
  disabled={disabled}
  readonly={readonly}
  rows={rows}
  maxlength={maxlength}
  minlength={minlength}
  aria-label={ariaLabel}
  aria-describedby={ariaDescribedby}
  aria-invalid={ariaInvalid}
  class={cn(textareaVariants({ variant, className }))}
>{value}</textarea>
