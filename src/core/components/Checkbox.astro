---
import { cva, type VariantProps } from 'class-variance-authority'

import { cn } from '@/core/utils/cn'

const checkboxVariants = cva(
  'relative shrink-0 box-border appearance-none cursor-pointer h-[22px] w-[22px] border-[3px] border-dp-black shadow-[3px_3px_0_theme(colors.dp-black)] transition-[background-color,box-shadow] duration-fast ease-out focus-visible:outline-none disabled:opacity-40 disabled:pointer-events-none disabled:cursor-not-allowed before:content-[""] before:absolute before:-inset-[11px] before:cursor-[inherit] checked:after:content-[""] checked:after:absolute checked:after:top-[45%] checked:after:left-1/2 checked:after:h-[8px] checked:after:w-[4px] checked:after:border-r-[2.5px] checked:after:border-b-[2.5px] checked:after:-translate-x-1/2 checked:after:-translate-y-1/2 checked:after:rotate-45',
  {
    variants: {
      variant: {
        default:
          'bg-dp-paper checked:bg-dp-red checked:after:border-dp-paper focus-visible:shadow-[3px_3px_0_theme(colors.dp-red)]',
        verified:
          'bg-dp-yellow checked:bg-dp-yellow checked:after:border-dp-black focus-visible:shadow-[3px_3px_0_theme(colors.dp-yellow-deep)]',
      },
    },
    defaultVariants: {
      variant: 'default',
    },
  },
)

interface Props extends VariantProps<typeof checkboxVariants> {
  name: string
  id?: string
  value?: string
  checked?: boolean
  required?: boolean
  disabled?: boolean
  'aria-describedby'?: string
  'aria-invalid'?: boolean | 'true' | 'false'
  'aria-label'?: string
  class?: string
}

const {
  name,
  id,
  value,
  checked = false,
  required = false,
  disabled = false,
  variant,
  'aria-describedby': ariaDescribedby,
  'aria-invalid': ariaInvalid,
  'aria-label': ariaLabel,
  class: className,
} = Astro.props
---

<input
  type="checkbox"
  name={name}
  id={id}
  value={value}
  checked={checked}
  required={required}
  disabled={disabled}
  aria-describedby={ariaDescribedby}
  aria-invalid={ariaInvalid}
  aria-label={ariaLabel}
  class={cn(checkboxVariants({ variant, className }))}
/>
